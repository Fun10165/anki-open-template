    "build:templates": "node scripts/build_templates.mjs",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc -p tsconfig.json",
    "build": "npm run typecheck && npm run lint && npm run build:templates",
    "test": "vitest run"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.1.0",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.10"
  },
  "version": "0.1.0",
  "private": true,
  "license": "GPL-3.0-only",
  "description": "Multi-format Anki card template build and packaging toolkit",
